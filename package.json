{
  "name": "shelf",
  "version": "0.1.0",
  "private": true,
  "description": "autoresearch for storefronts",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "seed": "tsx scripts/seed-store.ts",
    "export-trace": "tsx scripts/export-trace.ts"
  },
  "devDependencies": {
    "@shelf/core": "workspace:*",
    "@shopify/admin-api-client": "^1.0.8",
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2"
  }
}
