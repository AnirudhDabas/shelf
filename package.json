{
  "name": "shelf-ai",
  "version": "0.1.2",
  "description": "Autonomous optimization loop for Shopify product catalogs — makes AI shopping agents actually surface your products",
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "shelf-ai": "./packages/core/dist/cli.js"
  },
  "files": [
    "packages/core/dist/**",
    "packages/core/package.json",
    "README.md",
    "LICENSE"
  ],
  "author": "Anirudh Dabas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AnirudhDabas/shelf"
  },
  "homepage": "https://github.com/AnirudhDabas/shelf",
  "keywords": [
    "shopify",
    "ai",
    "seo",
    "cli",
    "optimization",
    "chatgpt",
    "perplexity",
    "ecommerce",
    "autoresearch"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "seed": "tsx scripts/seed-store.ts",
    "export-trace": "tsx scripts/export-trace.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "@shopify/admin-api-client": "^1.0.8",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "dotenv": "^16.4.5",
    "nanoid": "^5.0.7",
    "openai": "^4.67.3",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@shelf/core": "workspace:*",
    "@types/node": "^22.7.4",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "turbo": "^2.1.3",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.58.2"
  }
}
