{
  "name": "@shelf/core",
  "version": "0.1.1",
  "description": "shelf — autoresearch engine for Shopify catalog optimization",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "shelf-ai": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist .turbo",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@shopify/admin-api-client": "^1.0.8",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "nanoid": "^5.0.7",
    "openai": "^6.34.0",
    "ora": "^8.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.2"
  }
}
