# Shopify
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Admin API auth — either OAuth client credentials (preferred — auto-refreshing
# 24h tokens) or a long-lived shpat_ access token. If both are set, client
# credentials win.
SHOPIFY_CLIENT_ID=xxxxx
SHOPIFY_CLIENT_SECRET=xxxxx
# SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxx

SHOPIFY_STOREFRONT_ACCESS_TOKEN=xxxxx

# Scoring Providers (BYOK — bring your own keys)
PERPLEXITY_API_KEY=pplx-xxxxx
OPENAI_API_KEY=sk-xxxxx
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Optional
SHELF_BUDGET_LIMIT_USD=25
SHELF_MAX_ITERATIONS=100
SHELF_QUERIES_PER_MEASUREMENT=3
SHELF_LOG_FILE=shelf.jsonl
SHELF_SESSION_FILE=shelf.md
